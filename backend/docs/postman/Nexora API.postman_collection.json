{
  "info": {
    "name": "Nexora API — Sprint 7 (Proposal Review)",
    "description": "Collection for the Proposal Review Workflow endpoints added in Sprint 7.\n\n**Auth:** Register/Login first, then use the `/auth/login` response `access_token` as a Bearer token in the `Authorization` header.\n\n**Base URL:** `http://localhost:8000/api/v1`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester@example.com\",\n  \"password\": \"StrongPass1\",\n  \"full_name\": \"API Tester\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester@example.com\",\n  \"password\": \"StrongPass1\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Proposals — CRUD",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Website Redesign\",\n  \"description\": \"Full redesign of company website.\",\n  \"budget_min\": 2000,\n  \"budget_max\": 8000,\n  \"currency\": \"USD\",\n  \"status\": \"open\"\n}"
            }
          }
        },
        {
          "name": "Create Proposal",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"cover_letter\": \"I am excited to propose...\",\n  \"bid_amount\": 3500.00,\n  \"bid_type\": \"fixed\",\n  \"estimated_duration\": \"4 weeks\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Proposals — Review Workflow",
      "item": [
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/proposals/{{proposal_id}}/readiness",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Review (→ Under Review)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals/{{proposal_id}}/review",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Mark Ready (→ Ready to Submit)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals/{{proposal_id}}/ready",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Mark Submitted (→ Submitted)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals/{{proposal_id}}/submitted",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Archive",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals/{{proposal_id}}/archive",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Proposals — Versioning",
      "item": [
        {
          "name": "Edit Proposal (new version)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals/{{proposal_id}}/edit",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cover_letter\": \"Updated proposal content...\",\n  \"bid_amount\": 4000.00,\n  \"change_summary\": \"Adjusted pricing based on scope change\"\n}"
            }
          }
        },
        {
          "name": "List Versions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/proposals/{{proposal_id}}/versions",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Get Version",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/proposals/{{proposal_id}}/versions/{{version_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Rollback to Version",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals/{{proposal_id}}/rollback",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version_id\": \"{{version_id}}\",\n  \"change_summary\": \"Rolling back to previous scope\"\n}"
            }
          }
        },
        {
          "name": "Compare Versions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/proposals/{{proposal_id}}/compare?v1={{version_id_1}}&v2={{version_id_2}}",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Proposals — Notes",
      "item": [
        {
          "name": "List Notes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/proposals/{{proposal_id}}/notes",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/proposals/{{proposal_id}}/notes",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Client mentioned budget flexibility.\"\n}"
            }
          }
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/proposals/notes/{{note_id}}",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Updated: budget confirmed at $4k.\"\n}"
            }
          }
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/proposals/notes/{{note_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Proposals — Audit Log",
      "item": [
        {
          "name": "Get Audit Log",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/proposals/{{proposal_id}}/audit-log",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "project_id",
      "value": ""
    },
    {
      "key": "proposal_id",
      "value": ""
    },
    {
      "key": "version_id",
      "value": ""
    },
    {
      "key": "version_id_1",
      "value": ""
    },
    {
      "key": "version_id_2",
      "value": ""
    },
    {
      "key": "note_id",
      "value": ""
    }
  ]
}
