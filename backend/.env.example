# ------------------------------------------------------------------------
# Nexora AI backend — environment template
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`
# (it is already listed in .gitignore).
# ------------------------------------------------------------------------

# --- Application ---
ENVIRONMENT=development          # development | staging | production | test
DEBUG=true
APP_VERSION=1.0.0

# --- Security / JWT ---
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-64-character-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Database ---
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://nexora:nexora@localhost:5432/nexora
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_DEFAULT=100/minute

# --- LLM / AI ---
# Supported providers: openai, claude, gemini, deepseek
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-001
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Freelancer OAuth ---
# Create an app at https://accounts.freelancer.com/settings/create_app
# Set the redirect URI to: http://localhost:3000/api/integrations/freelancer/callback
FREELANCER_CLIENT_ID=
FREELANCER_CLIENT_SECRET=

# --- Marketplace (token encryption + frontend URL) ---
# Generate TOKEN_ENCRYPTION_KEY with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FRONTEND_URL=http://localhost:3000
TOKEN_ENCRYPTION_KEY=

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true

# --- Postgres container credentials (used by docker-compose.yml) ---
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora
POSTGRES_DB=nexora
