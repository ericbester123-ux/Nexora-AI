# ------------------------------------------------------------------------
# Nexora AI backend — environment configuration
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`
# (it is already listed in .gitignore).
# ------------------------------------------------------------------------

# --- Application ---
ENVIRONMENT=development          # development | staging | production | test
DEBUG=true
APP_VERSION=1.0.0

# --- Security / JWT ---
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-64-character-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Database ---
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://nexora:nexora@localhost:5432/nexora
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (comma-separated list of allowed origins) ---
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_DEFAULT=100/minute

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true

# --- Postgres container credentials (used by docker-compose.yml) ---
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora
POSTGRES_DB=nexora
